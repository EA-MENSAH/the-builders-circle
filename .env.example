# The Builders Circle — environment
#
# Copy this file to ".env" and paste your Supabase project's values.
# Find them in Supabase dashboard → Project Settings → API.
#
# Leave BOTH blank to run the app in offline mock mode (local data, no backend).
# Set BOTH to switch on real magic-link auth + shared data.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
